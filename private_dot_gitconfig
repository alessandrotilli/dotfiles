[alias]
  co = checkout
  cm = commit
  br = branch
  tree = log --graph --abbrev-commit --decorate --format=format:'%C(blue)%h%C(reset) - %C(green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
  treec = log --graph --abbrev-commit --decorate --format=format:'%C(blue)%h%C(reset) - %C(green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'

[user]
  name = Alessandro Tilli
  email = alessandro.tilli@gmail.com

[core]
  excludesfile = /Users/ale/.gitignore_global

[pull]
  ff = only

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[init]
  defaultBranch = main

[includeIf "gitdir:~/dev/kyp/"]
  path = .gitconfig-digitalnology
[includeIf "gitdir:~/dev/iot/"]
  path = .gitconfig-digitalnology
[includeIf "gitdir:~/dev/infrastructure/"]
  path = .gitconfig-digitalnology
[includeIf "gitdir:~/dev/tt/"]
  path = .gitconfig-digitalnology

[delta]
  features = navigate
  side-by-side = true
  true-color = always
