{
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  // "[typescript]": {
  //   "editor.defaultFormatter": "vscode.typescript-language-features",
  // },
  // "[javascript]": {
  //   "editor.defaultFormatter": "vscode.typescript-language-features",
  // },
  "workbench.startupEditor": "none",
  "window.confirmBeforeClose": "always",
  "telemetry.telemetryLevel": "off",
  "gitlens.views.commitDetails.files.layout": "tree",
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "workbench.iconTheme": "Monokai Pro (Filter Ristretto) Icons",
  "workbench.colorTheme": "Kanagawa Wave",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.minimap.enabled": false,
  "git.mergeEditor": true,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.fontFamily": "'CodeNewRoman Nerd Font Mono', Menlo, 'Jetbrains Mono', 'Cascadia Code', 'Fira Code', monospace",
  "editor.fontSize": 13,
  "terminal.integrated.fontSize": 13,
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[graphql]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "eslint.useFlatConfig": true,
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "prettier.enable": true,
  "eslint.format.enable": true,
  "[dockerfile]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "eslint.ignoreUntitled": true,
  "eslint.validate": [
    "astro",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "graphql",
  ],
  "eslint.probe": [
    "astro",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "graphql",
  ],
  "json.format.enable": false,
  "typescript.format.enable": false,
  "files.associations": {
    ".env.production": "properties",
    ".env.development.local": "properties",
    "*.env": "properties",
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop",
  ],
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "geminicodeassist.displayInlineContextHint": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "git.openRepositoryInParentFolders": "never",
  "editor.formatOnSave": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
}
